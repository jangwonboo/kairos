{
  "name": "kairos",
  "version": "0.1.0",
  "description": "Kairos — the right words, at the right time. A literary quote clock for Windows desktop.",
  "main": "./out/main/index.js",
  "author": "",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "package": "npm run build && electron-builder",
    "fetch-quotes": "tsx --env-file=.env scripts/1-fetch-quotes.ts",
    "translate-quotes": "tsx --env-file=.env scripts/2-translate-quotes.ts",
    "extract-keywords": "tsx --env-file=.env scripts/3-extract-keywords.ts",
    "build-quotes-json": "tsx --env-file=.env scripts/4-build-quotes-json.ts",
    "pipeline": "npm run fetch-quotes && npm run translate-quotes && npm run extract-keywords && npm run build-quotes-json",
    "pipeline:no-keywords": "npm run fetch-quotes && npm run translate-quotes && npm run build-quotes-json"
  },
  "dependencies": {
    "@fontsource/eb-garamond": "^5.2.7",
    "papaparse": "^5.4.1",
    "pretendard": "^1.3.9"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  }
}
